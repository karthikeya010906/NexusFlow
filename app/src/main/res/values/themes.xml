        <item name="colorOnSurface">@color/fire_light_text</item>
        <item name="colorOnSurfaceVariant">@color/fire_light_sub</item>
        <item name="colorOutline">@color/fire_light_border</item>
        <item name="colorPrimaryContainer">#FFE0E0</item>
        <item name="android:statusBarColor">@color/fire_light_bg</item>
        <item name="android:navigationBarColor">@color/fire_light_surface</item>
    </style>

