<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Theme -->
    <style name="Theme.NexusFlow" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="bottomSheetDialogTheme">@style/BottomSheetDialogTheme</item>
    </style>

    <!-- Fire Dark -->
    <style name="Theme.NexusFlow.Fire.Dark" parent="Theme.NexusFlow">
        <item name="colorPrimary">@color/fire_dark_accent</item>
        <item name="colorSecondary">@color/fire_dark_accent2</item>
        <item name="android:windowBackground">@color/fire_dark_bg</item>
        <item name="colorSurface">@color/fire_dark_surface</item>
        <item name="colorSurfaceVariant">@color/fire_dark_card</item>
        <item name="colorOnSurface">@color/fire_dark_text</item>
        <item name="colorOnSurfaceVariant">@color/fire_dark_sub</item>
        <item name="colorOutline">@color/accent_red</item>
        <item name="colorPrimaryContainer">#4D1A1A</item>
        <item name="android:statusBarColor">@color/fire_dark_bg</item>
        <item name="android:navigationBarColor">@color/fire_dark_surface</item>
    </style>

    <!-- Fire Light -->
    <style name="Theme.NexusFlow.Fire.Light" parent="Theme.NexusFlow">
        <item name="colorPrimary">@color/fire_light_accent</item>
